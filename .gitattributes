# 统一换行符，避免不同 OS 协作时 diff 噪音
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf
*.cfg text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Shell
*.sh text eol=lf
*.bash text eol=lf

# 文档
*.md text eol=lf
LICENSE text eol=lf

# 不要 diff
*.db binary
*.db-journal binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
